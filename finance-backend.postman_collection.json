            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500,\n  \"type\": \"expense\",\n  \"category\": \"food\",\n  \"date\": \"2025-01-01\",\n  \"note\": \"pizza\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/records",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["records"]
            }
          }
        },
        {
          "name": "Get Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
